{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar",
            "type": "process",
            "command": "mvn",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "compile"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Executar",
            "type": "process",
            "command": "mvn",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "args": [
                "exec:java"
            ],
            "dependsOn": "Compilar",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
